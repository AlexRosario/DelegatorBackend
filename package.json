{
	"name": "delegatorbackend",
	"version": "1.0.0",
	"main": "index.js",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc && prisma generate",
		"dev": "ts-node server.ts",
		"start": "prisma migrate deploy && node dist/server.js",
		"prisma:generate": "prisma generate",
		"migrate:dev": "prisma migrate dev",
		"migrate:deploy": "prisma migrate deploy",
		"ingest:bills": "npm run build && node dist/src/workers/dailyBillIngest.js",
		"ingest:bills:dev": "ts-node src/workers/dailyBillIngest.ts",
		"ingest:members": "npm run build && node dist/src/workers/dailyMemberIngest.js",
		"ingest:members:dev": "ts-node src/workers/dailyMemberIngest.ts",
		"ingest:backfill": "npm run build && node dist/src/workers/backfillBills.js",
		"reconcile:delegations": "npm run build && node dist/src/workers/reconcileDelegations.js",
		"backfill:rollcalls": "ts-node src/workers/backfillRollCalls.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/cheerio": "^0.22.35",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^4.17.23",
		"@types/node": "^24.0.3",
		"@types/node-cron": "^3.0.11",
		"@types/node-fetch": "^2.6.12",
		"prisma": "^6.10.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.109.0",
		"@libsql/client": "^0.17.0",
		"@prisma/adapter-better-sqlite3": "^7.2.0",
		"@prisma/adapter-libsql": "^7.2.0",
		"@prisma/client": "^6.10.1",
		"@types/dotenv": "^6.1.1",
		"@types/jsonwebtoken": "^9.0.10",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.6.0",
		"cheerio": "^1.1.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^16.6.1",
		"express": "^4.18.2",
		"express-async-errors": "^3.1.1",
		"jsonwebtoken": "^9.0.2",
		"node-cron": "^4.5.0",
		"node-fetch": "^2.7.0",
		"nodemon": "^3.1.10",
		"openai": "^5.9.0",
		"tsconfig-paths": "^4.2.0",
		"zod": "^3.25.67",
		"zod-express-middleware": "^1.4.0"
	}
}
