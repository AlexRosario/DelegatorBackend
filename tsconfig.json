{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"rootDir": "./",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": "src",
		"paths": {
			"@/*": ["*"]
		},
		"skipLibCheck": true
	},
	"include": ["server.ts", "src/**/*"],
	"exclude": ["node_modules"]
}
